Après 5 secondes, on revient automatiquement à IDLE :

C++

const unsigned long STATE_DURATION = 5000;  // 5000 ms = 5 secondes

if (now - stateStartMillis >= STATE_DURATION)
{
  currentState = IDLE_STATE;  // Retour à l'attente
}
7. Le moteur - Ouverture/Fermeture
C++

void ouverture()
{
  Motor.speed(MOTOR1, 255);   // Tourne dans un sens (ouvre)
  delay(2000);                // Pendant 2 secondes
  Motor.speed(MOTOR1, 0);     // S'arrête
}

void fermeture()
{
  Motor.speed(MOTOR1, -255);  // Tourne dans l'autre sens (ferme)
  delay(2000);                // Pendant 2 secondes
  Motor.speed(MOTOR1, 0);     // S'arrête
}
8. La boucle principale - loop()
C++

void loop()
{
  readTags();    // 1. Vérifie si une carte est présentée
  updateLEDs();  // 2. Met à jour l'écran, les LEDs et le moteur
}
🔄 Cette boucle tourne en permanence, des centaines de fois par seconde.

