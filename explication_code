4. Le setup() - L'initialisation
C++

void setup()
{
  Motor.begin(I2C_ADDRESS);     // Démarre le moteur

  lcd.begin(16, 2);             // Démarre l'écran (16 colonnes, 2 lignes)
  lcd.setRGB(255, 128, 0);      // Couleur orange
  lcd.print("Serrure fermee");  // Affiche le texte

  pixels.begin();               // Démarre les LEDs
  setALLpixels(255, 128, 0);    // LEDs en orange

  RFID.begin(9600);             // Démarre le lecteur RFID
  Serial.begin(9600);           // Démarre le moniteur série (debug)
}
🏁 Cette fonction s'exécute une seule fois au démarrage.

5. La lecture RFID - readTags()
C++

void readTags()
{
  // 1. Vérifie si une carte est présente
  if (RFID.available() < 14) return;  // Pas assez de données → on sort

  // 2. Lit les 14 octets de la carte
  for (int z = 0; z < 14; z++)
    newtag[z] = RFID.read();

  // 3. Compare avec la carte autorisée
  if (comparetag(newtag, tag))
  {
    // ✅ CARTE ACCEPTÉE
    currentState = ACCEPTED_STATE;
    digitalWrite(yes, HIGH);       // Allume la LED verte physique
  }
  else
  {
    // ❌ CARTE REFUSÉE
    currentState = REFUSED_STATE;
    digitalWrite(no, HIGH);        // Allume la LED rouge physique
  }
}
La comparaison des cartes
C++

boolean comparetag(int aa[], int bb[])
{
  int matchCount = 0;
  for (int i = 0; i < 14; i++)
  {
    if (aa[i] == bb[i]) matchCount++;  // Compte les octets identiques
  }
  return (matchCount == 14);  // Les 14 doivent correspondre !
}
📊 C'est comme comparer deux codes PIN chiffre par chiffre.

6. La mise à jour de l'affichage - updateLEDs()
Cette fonction gère ce qui se passe dans chaque état :

